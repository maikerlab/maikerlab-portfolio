  </div>

  <div class="mb-5">
    <div class="text-3xl w-full font-bold">Education</div>
  </div>

  <div class="time-line-container grid gap-4 mb-10">
    <TimeLineElement
      title="B. Sc. Computer Science of Technical Systems"
      subtitle="2020 to 2024 at HAW Hamburg (University of Applied Sciences), Germany"
    />
    <TimeLineElement
      title="State-certificed technician - Electrical Engineering, focus on data processing"
